{
    "name": "wasser",
    "displayName": "Wasser",
    "version": "5.0.0-beta.34",
    "author": "Smart Code OOD",
    "private": true,
    "main": "electron/main.cjs",
    "license": "gpl-2.0",
    "scripts": {
        "dev": "concurrently -k \"bun run dev:web\" \"wait-on tcp:8080 && ELECTRON_RENDERER_URL=http://127.0.0.1:8080 electron .\"",
        "dev:web": "vite",
        "start": "bun run dev",
        "build": "vite build",
        "build:renderer": "VITE_DISABLE_SERVICE_WORKER=true vite build",
        "dev:desktop": "bun run dev",
        "build:desktop": "bun run build:renderer && electron-builder --dir",
        "dist:desktop": "bun run build:renderer && electron-builder",
        "dist:mac": "bun run build:renderer && electron-builder --mac",
        "dist:win": "bun run build:renderer && electron-builder --win",
        "dist:linux": "bun run build:renderer && electron-builder --linux",
        "preview": "vite preview --host 0.0.0.0 --port 8080",
        "test": "vitest run",
        "lint": "eslint src",
        "scan-translations": "vitest run tests/i18nScan.test.js",
        "serve": "bun http_server.js"
    },
    "dependencies": {
        "@babel/runtime": "7.26.0",
        "@sentry/browser": "8.42.0",
        "@stremio/stremio-colors": "5.2.0",
        "@stremio/stremio-core-web": "0.56.4",
        "@stremio/stremio-icons": "5.8.0",
        "@stremio/stremio-video": "0.0.75",
        "a-color-picker": "1.2.1",
        "bowser": "2.11.0",
        "buffer": "6.0.3",
        "classnames": "2.5.1",
        "eventemitter3": "5.0.1",
        "fast-equals": "^6.0.0",
        "filter-invalid-dom-props": "3.0.1",
        "hat": "^0.0.3",
        "i18next": "^24.0.5",
        "langs": "github:Stremio/nodejs-langs",
        "lodash.debounce": "4.0.8",
        "lodash.intersection": "4.4.0",
        "lodash.throttle": "4.1.1",
        "magnet-uri": "6.2.0",
        "prop-types": "15.8.1",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-focus-lock": "2.13.2",
        "react-i18next": "^15.1.3",
        "react-is": "18.3.1",
        "spatial-navigation-polyfill": "github:Stremio/spatial-navigation#64871b1422466f5f45d24ebc8bbd315b2ebab6a6",
        "stremio-translations": "github:Stremio/stremio-translations#90ea718c18750a0e9cd6824b0ef7c512a41cb90b",
        "url": "0.11.4",
        "use-long-press": "^3.2.0"
    },
    "devDependencies": {
        "@babel/parser": "^7.28.0",
        "@eslint/js": "^9.16.0",
        "@originjs/vite-plugin-commonjs": "^1.0.3",
        "@stylistic/eslint-plugin": "^5.4.0",
        "@stylistic/eslint-plugin-jsx": "^4.4.1",
        "@vitejs/plugin-react": "^5.0.4",
        "@types/hat": "^0.0.4",
        "@types/lodash.throttle": "^4.1.9",
        "@types/node": "^24.7.2",
        "@types/react": "^18.3.13",
        "@types/react-dom": "^18.3.1",
        "concurrently": "^9.2.1",
        "electron": "^37.2.0",
        "electron-builder": "^26.0.12",
        "eslint": "^9.16.0",
        "eslint-plugin-react": "^7.37.2",
        "globals": "^15.13.0",
        "readdirp": "4.0.2",
        "recast": "0.23.11",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.17.0",
        "vite": "^7.1.12",
        "vite-plugin-pwa": "^1.1.0",
        "vitest": "^3.2.4",
        "wait-on": "^8.0.5"
    },
    "build": {
        "appId": "com.wasser.desktop",
        "productName": "Wasser",
        "directories": {
            "buildResources": "public/assets"
        },
        "files": [
            "build/**/*",
            "electron/**/*",
            "package.json"
        ],
        "extraMetadata": {
            "main": "electron/main.cjs"
        },
        "mac": {
            "category": "public.app-category.entertainment",
            "target": [
                "dmg",
                "zip"
            ],
            "icon": "public/assets/images/icon_512x512.png"
        },
        "win": {
            "target": [
                "nsis",
                "zip"
            ],
            "icon": "public/assets/images/icon_512x512.png"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "public/assets/images"
        }
    }
}
